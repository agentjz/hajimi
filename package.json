{
  "name": "@jun133/hajimi",
  "version": "0.1.2",
  "description": "A global terminal AI coding assistant.",
  "keywords": [
    "hajimi",
    "cli",
    "ai",
    "agent",
    "coding"
  ],
  "bin": {
    "hajimi": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format cjs --platform node --target node20 --outDir dist --clean --sourcemap && node scripts/copy-remote-assets.mjs dist/remote-web",
    "check": "npm run typecheck && npm run build",
    "clear": "python scripts/clear.py",
    "dev": "tsx src/cli.ts",
    "test:build": "tsc -p tsconfig.tests.json",
    "test:core": "npm run test:build && node --test .test-build/tests/**/*.test.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "npm run check && npm run test:core"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.9.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "diff": "^8.0.2",
    "docx": "^9.5.1",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "env-paths": "^3.0.0",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "mammoth": "^1.10.0",
    "marked": "^17.0.4",
    "openai": "^6.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
